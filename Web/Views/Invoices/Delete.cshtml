@model DTO.DataAccess.DataAccess.DTO.InvoiceEntity
@{
    ViewData["Title"] = "Delete Invoices";
}
<h1>Delete Invoices</h1>
<dl class="row">
    <dt class="col-sm-2">Date</dt><dd class="col-sm-10">@Model.InvoiceDate</dd>
    <dt class="col-sm-2">Address</dt><dd class="col-sm-10">@Model.Address.Name</dd>
    <dt class="col-sm-2">Service</dt><dd class="col-sm-10">@Model.Service.Name</dd>
    <dt class="col-sm-2">Total</dt><dd class="col-sm-10">@Model.TotalSum</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
