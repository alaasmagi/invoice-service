@model IEnumerable<DTO.DataAccess.DataAccess.DTO.InvoiceEntity>
@{
    ViewData["Title"] = "Invoices";
}
<h1>Invoices</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
    <a asp-controller="InvoiceImports" asp-action="Upload" class="btn btn-outline-primary">Import PDF</a>
</p>
<table class="table">
    <thead><tr><th>Date</th><th>Address</th><th>Service</th><th>Total</th><th></th></tr></thead>
    <tbody>
@foreach (var item in Model) {
    <tr><td>@item.InvoiceDate</td><td>@item.Address.Name</td><td>@item.Service.Name</td><td>@item.TotalSum</td><td><a asp-action="Edit" asp-route-id="@item.Id">Edit</a> | <a asp-action="Details" asp-route-id="@item.Id">Details</a> | <a asp-action="Delete" asp-route-id="@item.Id">Delete</a></td></tr>
}
    </tbody>
</table>
