@model Web.Models.MonthlyStatementDetailViewModel
@{
    ViewData["Title"] = "Monthly Statement Details";
}
<h1>Monthly Statement Details</h1>
@if (TempData["StatusMessage"] is string message)
{
    <div class="alert alert-info">@message</div>
}
<section class="mb-4">
    <h2>@Model.Statement.Contact.FullName - @Model.Statement.Period</h2>
    <dl class="row">
        <dt class="col-sm-2">Addresses</dt><dd class="col-sm-10">@string.Join(", ", Model.AddressNames)</dd>
        <dt class="col-sm-2">Total</dt><dd class="col-sm-10">@Model.Statement.TotalSum</dd>
        <dt class="col-sm-2">Status</dt><dd class="col-sm-10">@Model.Statement.Status</dd>
        <dt class="col-sm-2">Sent At</dt><dd class="col-sm-10">@Model.Statement.SentAt</dd>
    </dl>
    @if (Model.CanSend)
    {
        <form asp-action="Send" asp-route-id="@Model.Statement.Id" method="post">
            <button type="submit" class="btn btn-primary">
                @(Model.Statement.Status == Domain.EMonthlyStatementStatus.Sent ? "Send again" : "Send")
            </button>
        </form>
    }
</section>
<section class="mb-4">
    <h3>Invoice Shares</h3>
    <table class="table">
        <thead><tr><th>Address</th><th>Service</th><th>Invoice Date</th><th>Period</th><th>Invoice Total</th><th>Split</th><th>Person Share</th></tr></thead>
        <tbody>
@foreach (var line in Model.Lines) {
            <tr>
                <td>@line.AddressName</td>
                <td>@line.ServiceName</td>
                <td>@line.InvoiceDate</td>
                <td>@line.PeriodStart - @line.PeriodEnd</td>
                <td>@line.InvoiceTotal</td>
                <td>@line.ResidentCount</td>
                <td>@line.AllocatedAmount</td>
            </tr>
}
        </tbody>
    </table>
</section>
<p><a asp-action="Edit" asp-route-id="@Model.Statement.Id">Edit</a> | <a asp-action="Index">Back</a></p>
