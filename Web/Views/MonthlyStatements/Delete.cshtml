@model DTO.DataAccess.DataAccess.DTO.MonthlyStatementEntity
@{
    ViewData["Title"] = "Delete Monthly Statement";
}
<h1>Delete Monthly Statement</h1>
<p>Are you sure you want to delete this statement?</p>
<dl class="row">
    <dt class="col-sm-2">Person</dt><dd class="col-sm-10">@Model.Contact.FullName</dd>
    <dt class="col-sm-2">Period</dt><dd class="col-sm-10">@Model.Period</dd>
    <dt class="col-sm-2">Total</dt><dd class="col-sm-10">@Model.TotalSum</dd>
    <dt class="col-sm-2">Status</dt><dd class="col-sm-10">@Model.Status</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
