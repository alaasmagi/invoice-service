@model DTO.DataAccess.DataAccess.DTO.InvoiceAllocationEntity
@{
    ViewData["Title"] = "Edit Invoice Allocations";
}
<h1>Edit Invoice Allocations</h1>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3"><label asp-for="InvoiceId" class="form-label"></label><select asp-for="InvoiceId" class="form-select" asp-items="ViewBag.InvoiceId"></select></div>
    <div class="mb-3"><label asp-for="ContactId" class="form-label"></label><select asp-for="ContactId" class="form-select" asp-items="ViewBag.ContactId"></select></div>
    <div class="mb-3"><label asp-for="AllocatedSum" class="form-label"></label><input asp-for="AllocatedSum" class="form-control" /></div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
