@model DTO.DataAccess.DataAccess.DTO.InvoiceAllocationEntity
@{
    ViewData["Title"] = "Delete Invoice Allocations";
}
<h1>Delete Invoice Allocations</h1>
<dl class="row">
    <dt class="col-sm-2">Invoice</dt><dd class="col-sm-10">@Model.Invoice.InvoiceDate - @Model.Invoice.Address.Name</dd>
    <dt class="col-sm-2">Contact</dt><dd class="col-sm-10">@Model.Contact.FullName</dd>
    <dt class="col-sm-2">Amount</dt><dd class="col-sm-10">@Model.AllocatedSum</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
