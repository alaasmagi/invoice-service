@model IEnumerable<DTO.DataAccess.DataAccess.DTO.AddressContactEntity>
@{
    ViewData["Title"] = "Address Contacts";
}
<h1>Address Contacts</h1>
<p><a asp-action="Create" class="btn btn-primary">Create New</a></p>
<table class="table">
    <thead><tr><th>Address</th><th>Contact</th><th>Start</th><th>End</th><th></th></tr></thead>
    <tbody>
@foreach (var item in Model) {
    <tr><td>@item.Address.Name</td><td>@item.Contact.FullName</td><td>@item.StartDate</td><td>@item.EndDate</td><td><a asp-action="Edit" asp-route-id="@item.Id">Edit</a> | <a asp-action="Details" asp-route-id="@item.Id">Details</a> | <a asp-action="Delete" asp-route-id="@item.Id">Delete</a></td></tr>
}
    </tbody>
</table>
