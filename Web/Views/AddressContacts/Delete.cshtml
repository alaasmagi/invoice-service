@model DTO.DataAccess.DataAccess.DTO.AddressContactEntity
@{
    ViewData["Title"] = "Delete Address Contacts";
}
<h1>Delete Address Contacts</h1>
<dl class="row">
    <dt class="col-sm-2">Address</dt><dd class="col-sm-10">@Model.Address.Name</dd>
    <dt class="col-sm-2">Contact</dt><dd class="col-sm-10">@Model.Contact.FullName</dd>
    <dt class="col-sm-2">Start</dt><dd class="col-sm-10">@Model.StartDate</dd>
    <dt class="col-sm-2">End</dt><dd class="col-sm-10">@Model.EndDate</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
