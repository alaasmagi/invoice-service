@model DTO.DataAccess.DataAccess.DTO.AddressContactEntity
@{
    ViewData["Title"] = "Create Address Contacts";
}
<h1>Create Address Contacts</h1>
<form asp-action="Create" method="post">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3"><label asp-for="AddressId" class="form-label"></label><select asp-for="AddressId" class="form-select" asp-items="ViewBag.AddressId"></select></div>
    <div class="mb-3"><label asp-for="ContactId" class="form-label"></label><select asp-for="ContactId" class="form-select" asp-items="ViewBag.ContactId"></select></div>
    <div class="mb-3"><label asp-for="StartDate" class="form-label"></label><input asp-for="StartDate" class="form-control" type="date" /></div>
    <div class="mb-3"><label asp-for="EndDate" class="form-label"></label><input asp-for="EndDate" class="form-control" type="date" /></div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
