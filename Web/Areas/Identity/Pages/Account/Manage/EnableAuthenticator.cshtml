@page
@model Web.Areas.Identity.Pages.Account.Manage.EnableAuthenticatorModel

@{
    ViewData["Title"] = "Set up authenticator app";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-7">
        @if (Model.RecoveryCodes.Count > 0)
        {
            <div class="alert alert-warning" role="alert">
                Save these recovery codes before leaving this page.
            </div>
            <ul class="list-group mb-4">
                @foreach (var recoveryCode in Model.RecoveryCodes)
                {
                    <li class="list-group-item"><code>@recoveryCode</code></li>
                }
            </ul>
        }

        <ol>
            <li class="mb-3">
                <p>Scan this QR code with an authenticator app.</p>
                <div id="qrCode" class="border p-2 bg-white d-inline-block"></div>
                <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
            </li>
            <li class="mb-3">
                <p>Or enter this key manually: <kbd>@Model.SharedKey</kbd></p>
            </li>
            <li>
                <p>Enter the 6-digit code from the app.</p>
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Code" class="form-control" autocomplete="off" inputmode="numeric" placeholder="123456" />
                        <label asp-for="Input.Code">Verification code</label>
                        <span asp-validation-for="Input.Code" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">Verify and enable</button>
                </form>
            </li>
        </ol>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/davidshimjs-qrcodejs-04f46c6/qrcode.min.js"></script>
    <script src="~/js/qr.js" asp-append-version="true"></script>
}
