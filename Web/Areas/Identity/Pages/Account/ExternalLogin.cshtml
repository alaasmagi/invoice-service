@page
@model Web.Areas.Identity.Pages.Account.ExternalLoginModel

@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Register";
}

<h1>@ViewData["Title"]</h1>
<h2>Associate your @Model.ProviderDisplayName account.</h2>
<hr />

<p class="text-info">
    You've successfully authenticated with <strong>@Model.ProviderDisplayName</strong>.
    Enter the local account details for this site below.
</p>

<div class="row">
    <div class="col-md-5">
        <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Fullname" class="form-control" autocomplete="name" aria-required="true" placeholder="Full name" />
                <label asp-for="Input.Fullname" class="form-label">Full name</label>
                <span asp-validation-for="Input.Fullname" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">Register</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
