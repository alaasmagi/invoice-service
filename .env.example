# Copy this file to .env for local development and fill in real values.
# Configuration precedence: ASP.NET Core environment keys first, then these flat aliases, then safe appsettings defaults.

# Application HTTP port inside container/process (used to build ASPNETCORE_URLS when not set explicitly).
APP_PORT=8080

# Optional host port mapping for docker compose deployments.
HOST_PORT=8080

# PostgreSQL connection used by AppIdentityDbContext.
IDENTITY_CONNECTION_STRING=Host=localhost;Port=5432;Database=invoice_auth;Username=invoice_user;Password=change-me;Search Path=auth

# PostgreSQL connection used by AppDbContext.
APP_CONNECTION_STRING=Host=localhost;Port=5432;Database=invoice_app;Username=invoice_user;Password=change-me;Search Path=invoice

# Brevo transactional email settings.
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME=Invoice Service

# Optional: use Console only for local offline development. Default is Brevo.
EMAIL_PROVIDER=Brevo

# Optional external login providers. Register callback URLs:
# Google: /signin-google
# Microsoft: /signin-microsoft
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
